# Scrapling REST API - Environment Variables

# Server binding
HOST=0.0.0.0
PORT=8000

# API Key authentication
# Every request to scraping endpoints must include: X-API-Key: <key>
SCRAPLING_API_KEY=HfaSMsDz55k3gPwku8tIsZdne-p2N09JiHp3ZtrXY4A

SCRAPLING_API_KEY="HfaSMsDz55k3gPwku8tIsZdne-p2N09JiHp3ZtrXY4A"
SCRAPLING_API_URL="https://scrapling-production-b8ef.up.railway.app/api/dynamic/fetch"
SCRAPE_ATTEMPTS_INCOMPLETE_PROFILE="2"
SCRAPE_ATTEMPTS_COMPLETED_PROFILE="4"
SCRAPER_API_KEY="your_scraperapi_key"

SCRAPLING_MAX_BROWSERS=1
SCRAPLING_MAX_FETCHERS=10
# Backpressure / timeout tuning
SCRAPLING_BROWSER_QUEUE_TIMEOUT=120
SCRAPLING_EXECUTION_TIMEOUT=120
# Idle pooled browser lifetime in seconds. Lower values free resources faster.
SCRAPLING_BROWSER_TIMEOUT=60

# Safety limits
SCRAPLING_MAX_RESPONSE_SIZE=10485760
# Set this to enable API key protection on all scraping endpoints.
# When set, every request must include the header: X-API-Key: <your-key>
# Leave unset or empty to disable authentication (not recommended in production).
SCRAPLING_API_KEY=your-secret-api-key-here

# Browser concurrency
# Max simultaneous browser sessions (Playwright/Stealth). Each uses ~100-200MB RAM.
SCRAPLING_MAX_BROWSERS=1
# Max simultaneous HTTP fetcher requests (Fetcher/AsyncFetcher).
SCRAPLING_MAX_FETCHERS=10

# Timeouts (seconds)
# How long a request waits for a free browser slot before returning 503.
SCRAPLING_BROWSER_QUEUE_TIMEOUT=60
# Max total execution time per scraping request.
SCRAPLING_EXECUTION_TIMEOUT=120
# Browser inactivity timeout before session is closed.
SCRAPLING_BROWSER_TIMEOUT=120

# Safety limits
# Max response body size in bytes (default 10MB).
SCRAPLING_MAX_RESPONSE_SIZE=10485760

# Sentry error tracking (optional)
# Get your DSN from https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Telegram error alerts (optional)
# Sends crash/error notifications to a Telegram chat.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
