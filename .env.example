# Scrapling REST API - Environment Variables
# Copy this to .env and adjust as needed.
# Railway will inject PORT automatically — no need to set it there.

# Server binding
HOST=0.0.0.0
PORT=8000

# API Key authentication
# Set this to enable API key protection on all scraping endpoints.
# When set, every request must include the header: X-API-Key: <your-key>
# Leave unset or empty to disable authentication (not recommended in production).
SCRAPLING_API_KEY=your-secret-api-key-here

# Browser concurrency
# Max simultaneous browser sessions (Playwright/Stealth). Each uses ~100-200MB RAM.
SCRAPLING_MAX_BROWSERS=1
# Max simultaneous HTTP fetcher requests (Fetcher/AsyncFetcher).
SCRAPLING_MAX_FETCHERS=10

# Timeouts (seconds)
# How long a request waits for a free browser slot before returning 503.
SCRAPLING_BROWSER_QUEUE_TIMEOUT=60
# Max total execution time per scraping request.
SCRAPLING_EXECUTION_TIMEOUT=120
# Browser inactivity timeout before session is closed.
SCRAPLING_BROWSER_TIMEOUT=120

# Safety limits
# Max response body size in bytes (default 10MB).
SCRAPLING_MAX_RESPONSE_SIZE=10485760
